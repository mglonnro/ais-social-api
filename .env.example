# Copy to .env and fill in. server.js, db.js, scripts/migrate.mjs all
# auto-load .env via `import "dotenv/config"`.

# ---- HTTP ----
# Bind port. The npm scripts `start`/`startbeta` hardcode 3102/3103 and
# override this; `npm run dev` lets this value through.
PORT=3104

# ---- Postgres ----
# Production Postgres is Cloud SQL `naked-sailor:europe-west1:marinais-db-2`.
# Run `npm run tunnel` to bring up the Cloud SQL Auth Proxy on 5433 AND
# an SSH tunnel to the ais-server VM on 3105 in the same shell. One-time:
#   brew install cloud-sql-proxy
#   gcloud auth application-default login
# Then point PGHOST=127.0.0.1 PGPORT=5433 at the proxy and use the prod
# DB name + user + password. PORT 5433 keeps a local Postgres on 5432
# undisturbed if you have one. You are now writing to prod — be deliberate.
#
# Alternatively for an isolated local DB:
#   createdb ais_social_local; PGPORT=5432 PGDATABASE=ais_social_local
PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=
PGUSER=
PGPASSWORD=

# ---- AIS feed ----
# ais-server runs on marinais-vm1 (zone europe-west1-b) and binds to
# 127.0.0.1:3105. `npm run tunnel` forwards it via gcloud SSH so the
# default AIS_SERVER_URL below resolves through that tunnel. Or run a
# local ais-server.
AIS_SERVER_URL=ws://127.0.0.1:3105/

# ---- Auth ----
# JWT signing secret. Must match the msg-server. For local dev any value
# works; the JWTs you mint locally are scoped to the local DB.
JSON_SECRET=changeme-local-dev

# Inter-server secret for the API <-> msg-server bridge.
BACKEND_SECRET=changeme-local-dev

# Comma-separated list of user_id values that may call /admin/* endpoints
# (currently just POST /admin/boats/:mmsi/generate-topdown). Find your
# user_id in the `users` table.
ADMIN_USER_IDS=

# ---- External services ----
# Optional. Path to a GCP service account JSON with Storage Object Admin
# on the ais-social.appspot.com bucket. If you've done
# `gcloud auth application-default login` with a user that has bucket
# access in the `ais-social` project, leave this blank — both
# @google-cloud/storage and firebase-admin will pick up ADC. Verify with:
#   gsutil ls gs://ais-social.appspot.com/images/ | head
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/ais-social-service-account.json

# Gemini API key (https://aistudio.google.com/apikey). Required for the
# top-down icon generator; everything else runs without it.
GEMINI_API_KEY=

# Expo push token (only needed if you want push notifications to fire
# from local dev — usually leave blank).
EXPO_ACCESS_TOKEN=
